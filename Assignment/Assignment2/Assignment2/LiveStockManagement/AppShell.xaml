<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LiveStockManagement.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:LiveStockManagement"
    xmlns:pages="clr-namespace:LiveStockManagement.Pages"
    Title="LiveStockManagement">

    <TabBar>
        <ShellContent Shell.NavBarIsVisible="False" Title="Data Listing" ContentTemplate="{DataTemplate pages:DataPage}" />
        <ShellContent Shell.NavBarIsVisible="False" Title="Edit Data" ContentTemplate="{DataTemplate pages:EditDataPage}" />
        <ShellContent Shell.NavBarIsVisible="False" Title="Remove Data" ContentTemplate="{DataTemplate pages:RemoveDataPage}" />
        <ShellContent Shell.NavBarIsVisible="False" Title="Update Data" ContentTemplate="{DataTemplate pages:UpdateDataPage}" />
        <ShellContent Shell.NavBarIsVisible="False" Title="Statistics" ContentTemplate="{DataTemplate pages:StatisticsPage}" />
        <ShellContent Shell.NavBarIsVisible="False" Title="Profit Forecast" ContentTemplate="{DataTemplate pages:ProfitForecastPage}" />
    </TabBar>
</Shell>
