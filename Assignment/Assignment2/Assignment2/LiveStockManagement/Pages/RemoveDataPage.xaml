<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LiveStockManagement.Pages.RemoveDataPage"
             xmlns:pages="clr-namespace:LiveStockManagement.Pages"
             Title="RemoveDataPage">
    <VerticalStackLayout HorizontalOptions="Center">
        <!--Remove by id. Show confirmation before removing.-->
        <Entry x:Name="IdEntry" Placeholder="Enter Id to Remove" Keyboard="Numeric"/>
        <Button Text="Remove Record" Clicked="Remove"/>
    </VerticalStackLayout>
</ContentPage>