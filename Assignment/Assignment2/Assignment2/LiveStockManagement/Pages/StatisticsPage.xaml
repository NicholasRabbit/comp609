<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LiveStockManagement.Pages.StatisticsPage"
             Title="Statistics">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="10">

            <!-- ══════════════════════════════════════ -->
            <!--  HEADING                               -->
            <!-- ══════════════════════════════════════ -->
            <Label Text="Calculate Farm Livestock Statistics"
                   FontSize="18" FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,4"/>

            <!-- ══════════════════════════════════════ -->
            <!--  FILTERS                               -->
            <!-- ══════════════════════════════════════ -->
            <Label Text="Livestock Type:" FontAttributes="Bold"/>
            <Picker x:Name="TypePicker">
                <Picker.Items>
                    <x:String>All</x:String>
                    <x:String>Cow</x:String>
                    <x:String>Sheep</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Colour:" FontAttributes="Bold"/>
            <Picker x:Name="ColourPicker">
                <Picker.Items>
                    <x:String>All</x:String>
                    <x:String>Red</x:String>
                    <x:String>Black</x:String>
                    <x:String>White</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Days to Project:" FontAttributes="Bold"/>
            <Entry x:Name="DaysEntry" Keyboard="Numeric" Placeholder="Enter number of days"/>

            <Label x:Name="ErrorLabel" TextColor="Red" IsVisible="False"/>

            <Button x:Name="CalculateButton" Text="Calculate"
                    Clicked="OnCalculateClicked"
                    WidthRequest="200" HorizontalOptions="Center"
                    TextColor="White"/>

         
            <!--results-->
            <Frame x:Name="ResultsFrame" IsVisible="False"
                   BorderColor="#CCCCCC" Padding="12" CornerRadius="6">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Results" FontSize="16" FontAttributes="Bold"/>
                    <BoxView HeightRequest="1" Color="#DDDDDD"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total Selected Livestock:"/>
                        <Label x:Name="LblCount" Grid.Column="1" FontAttributes="Bold" HorizontalOptions="End"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Percentage of Livestock:"/>
                        <Label x:Name="LblPercentage" Grid.Column="1" FontAttributes="Bold" HorizontalOptions="End"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#DDDDDD"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total Tax Paid:"/>
                        <Label x:Name="LblTax" Grid.Column="1" FontAttributes="Bold" HorizontalOptions="End"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total Profit / Loss:"/>
                        <Label x:Name="LblProfit" Grid.Column="1" FontAttributes="Bold" HorizontalOptions="End"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Average Weight (kg):"/>
                        <Label x:Name="LblAvgWeight" Grid.Column="1" FontAttributes="Bold" HorizontalOptions="End"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#DDDDDD"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total Produce (Milk + Wool):"/>
                        <Label x:Name="LblProduce" Grid.Column="1" FontAttributes="Bold" HorizontalOptions="End"/>
                    </Grid>
                    <Grid ColumnDefinitions="16,*,Auto">
                        <Label Grid.Column="1" Text="↳ Total Milk (Cows):" TextColor="#555555"/>
                        <Label x:Name="LblMilk" Grid.Column="2" TextColor="#555555" HorizontalOptions="End"/>
                    </Grid>
                    <Grid ColumnDefinitions="16,*,Auto">
                        <Label Grid.Column="1" Text="↳ Total Wool (Sheep):" TextColor="#555555"/>
                        <Label x:Name="LblWool" Grid.Column="2" TextColor="#555555" HorizontalOptions="End"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!--  daily pofit -->
            <Frame x:Name="BreakdownFrame" IsVisible="False"
                   BorderColor="#2196F3" Padding="12" CornerRadius="6">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Daily Profit Breakdown" FontSize="16"
                           FontAttributes="Bold" TextColor="#2196F3"/>
                    <Label Text="Shown when Type = All and Colour = All"
                           FontSize="11" TextColor="#888888"/>
                    <BoxView HeightRequest="1" Color="#BBDEFB"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total Daily Cow Profit:"/>
                        <Label x:Name="LblTotalDailyCow" Grid.Column="1" FontAttributes="Bold" HorizontalOptions="End"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Avg Daily Cow Profit (per cow):"/>
                        <Label x:Name="LblAvgDailyCow" Grid.Column="1" FontAttributes="Bold" HorizontalOptions="End"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="#BBDEFB"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total Daily Sheep Profit:"/>
                        <Label x:Name="LblTotalDailySheep" Grid.Column="1" FontAttributes="Bold" HorizontalOptions="End"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Avg Daily Sheep Profit (per sheep):"/>
                        <Label x:Name="LblAvgDailySheep" Grid.Column="1" FontAttributes="Bold" HorizontalOptions="End"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
